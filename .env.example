# Geocodify API key — used to convert a location search into coordinates
# Get one at https://www.geocodify.com/
VITE_GEOCODIFY_API_KEY=your_geocodify_api_key_here

# OpenUV API key — used to fetch UV index data for a given lat/lng
# Get one at https://www.openuv.io/
VITE_OPENUV_API_KEY=your_openuv_api_key_here
